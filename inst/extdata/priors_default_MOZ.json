{
  "metadata": {
    "version": "3.1",
    "date": "2026-05-27",
    "description": "MOZ-specific informative prior distributions for extended 2017-2026 calibration. v3.1 (2026-04-29): rho_deaths added as a first-class global prior, Beta(3, 2), reflecting ~60% surveillance capture of true cholera deaths (Finger et al. 2024; laser-cholera#49). v3.0 (2026-04-23): zeta_1, zeta_2, and zeta_ratio re-estimated from literature meta-analysis (priors_default v15.0; ~6 OOM scale shift on zeta_1). Hardcoded from est_zeta_*_prior() output to keep MOZ build self-contained. Previous: updated from test_31 MOZ 6-7 analysis."
  },
  "parameters_global": {
    "alpha_1": {
      "description": "Population mixing within metapops (0-1, 1 = well-mixed)",
      "distribution": "beta",
      "parameters": {
        "shape1": 7,
        "shape2": 8
      }
    },
    "alpha_2": {
      "description": "Degree of frequency driven transmission (0-1)",
      "distribution": "beta",
      "parameters": {
        "shape1": 7.5,
        "shape2": 7.5
      }
    },
    "decay_days_spread": {
      "description": "Spread between min and max V. cholerae survival time (days)",
      "distribution": "truncnorm",
      "parameters": {
        "mean": 180,
        "sd": 95,
        "a": 1,
        "b": 365
      }
    },
    "decay_days_short": {
      "description": "Minimum V. cholerae survival time (days)",
      "distribution": "truncnorm",
      "parameters": {
        "mean": 16,
        "sd": 7,
        "a": 0.01,
        "b": 60
      }
    },
    "decay_shape_1": {
      "description": "First shape parameter of Beta distribution for V. cholerae decay",
      "distribution": "truncnorm",
      "parameters": {
        "mean": 3,
        "sd": 5,
        "a": 0.1,
        "b": 10
      }
    },
    "decay_shape_2": {
      "description": "Second shape parameter of Beta distribution for V. cholerae decay",
      "distribution": "truncnorm",
      "parameters": {
        "mean": 3,
        "sd": 5,
        "a": 0.1,
        "b": 10
      }
    },
    "epsilon": {
      "description": "Natural immunity waning rate (per day)",
      "distribution": "lognormal",
      "parameters": {
        "mean": 0.00039,
        "sd": 0.0004
      }
    },
    "gamma_1": {
      "description": "Symptomatic/severe shedding duration rate (per day)",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": -2.30258509299405,
        "sdlog": 0.5
      }
    },
    "gamma_2": {
      "description": "Asymptomatic/mild shedding duration rate (per day)",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": -0.693147180559945,
        "sdlog": 0.4
      }
    },
    "iota": {
      "description": "Incubation rate (1/days)",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": -0.337,
        "sdlog": 0.4
      }
    },
    "kappa": {
      "description": "Concentration of V. cholerae for 50% infectious dose",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": 13.8780105579643,
        "sdlog": 0.25
      }
    },
    "mobility_gamma": {
      "description": "Mobility distance decay parameter",
      "distribution": "gamma",
      "parameters": {
        "shape": 3.72436825806088,
        "rate": 2
      }
    },
    "mobility_omega": {
      "description": "Mobility population scaling parameter",
      "distribution": "gamma",
      "parameters": {
        "shape": 2.23280919493869,
        "rate": 2
      }
    },
    "omega_1": {
      "description": "Vaccine waning rate (one dose, per day)",
      "distribution": "gamma",
      "parameters": {
        "shape": 23.3299949171649,
        "rate": 31693.8276408133
      }
    },
    "omega_2": {
      "description": "Vaccine waning rate (two dose, per day)",
      "distribution": "gamma",
      "parameters": {
        "shape": 2.68783331145694,
        "rate": 4720.84484791329
      }
    },
    "phi_1": {
      "description": "Initial vaccine effectiveness (one dose)",
      "distribution": "beta",
      "parameters": {
        "shape1": 91.8430481703201,
        "shape2": 25.4934335058671
      }
    },
    "phi_2": {
      "description": "Initial vaccine effectiveness (two dose)",
      "distribution": "beta",
      "parameters": {
        "shape1": 206.957008924941,
        "shape2": 56.5308788594621
      }
    },
    "chi_endemic": {
      "description": "PPV among suspected cases during endemic periods (Weins et al. 2023, all settings)",
      "distribution": "beta",
      "parameters": {
        "shape1": 5.42988327430809,
        "shape2": 5.00904617715547
      }
    },
    "chi_epidemic": {
      "description": "PPV among suspected cases during epidemic periods (Weins et al. 2023, during outbreaks)",
      "distribution": "beta",
      "parameters": {
        "shape1": 4.78806160754615,
        "shape2": 1.53280128097088
      }
    },
    "rho": {
      "description": "Care-seeking rate: probability a symptomatic infection is reported as suspected (GEMS + Wiens 2025)",
      "distribution": "beta",
      "parameters": {
        "shape1": 6.81427258303886,
        "shape2": 17.8943797428517
      }
    },
    "rho_deaths": {
      "description": "Death detection rate: probability a true cholera death is captured by surveillance (Finger et al. 2024)",
      "distribution": "beta",
      "parameters": {
        "shape1": 3,
        "shape2": 2
      }
    },
    "sigma": {
      "description": "Proportion symptomatic",
      "distribution": "beta",
      "parameters": {
        "shape1": 4.3,
        "shape2": 13.51
      }
    },
    "zeta_1": {
      "description": "Symptomatic shedding rate (V. cholerae cells per infected person per day)",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": 25.654136,
        "sdlog": 2.458114
      }
    },
    "zeta_2": {
      "description": "Asymptomatic shedding rate (V. cholerae cells per infected person per day); derived at sampling time as zeta_1/zeta_ratio, this prior is the literature-derived reference for validation",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": 12.302179,
        "sdlog": 2
      }
    },
    "zeta_ratio": {
      "description": "Ratio of symptomatic to asymptomatic shedding rate (zeta_1 / zeta_2); direct literature-anchor channel (Smith 2026, Chao 2011, Finger 2018, Nelson 2009 paired, etc.)",
      "distribution": "lognormal",
      "parameters": {
        "meanlog": 4.313378,
        "sdlog": 4.393627
      }
    },
    "delta_reporting_cases": {
      "description": "Symptom-onset-to-case reporting delay in days (integer, 0-7)",
      "distribution": "truncnorm",
      "parameters": {
        "mean": 1,
        "sd": 1.5,
        "a": 0,
        "b": 7
      }
    },
    "delta_reporting_deaths": {
      "description": "Symptom-onset-to-death reporting delay in days (integer, 1-14)",
      "distribution": "truncnorm",
      "parameters": {
        "mean": 4,
        "sd": 3,
        "a": 1,
        "b": 14
      }
    }
  },
